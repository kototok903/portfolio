---
import { Badge } from "@/components/ui/badge"
import { tagsData } from "@/lib/tags"

interface Props {
  tag: string
}

const { tag } = Astro.props
const data = tagsData[tag]
---

{
  data && (
    <Badge variant="outline" className="cursor-default rounded-md">
      {data.icon && <img src={data.icon} alt={`${data.name} icon`} width="20" height="20" loading="lazy" />}
      {data.name}
    </Badge>
  )
}
