---
import { actions } from "astro:actions"
import { Button } from "@/components/ui/button"
import { Field, FieldGroup, FieldLabel } from "@/components/ui/field"
import { Input } from "@/components/ui/input"
import { Textarea } from "@/components/ui/textarea"
---

<section id="contact-form" class="relative isolate m-auto max-w-3xl scroll-mt-32">
  <h1 class="title">Contact me</h1>

  <form method="POST" action={actions.sendContact} class="mt-6 lg:flex-auto" data-contact-form>
    <div class="hidden" aria-hidden>
      <label>
        Website
        <input name="website" tabindex="-1" autocomplete="off" />
      </label>
    </div>

    <FieldGroup className="grid grid-cols-1 gap-6 sm:grid-cols-2">
      <Field>
        <FieldLabel htmlFor="name" className="sr-only">Name</FieldLabel>
        <Input
          id="name"
          name="name"
          type="text"
          placeholder="Name"
          autoComplete="given-name"
          minLength={2}
          required
        />
      </Field>

      <Field>
        <FieldLabel htmlFor="email" className="sr-only">Email</FieldLabel>
        <Input
          id="email"
          name="email"
          type="email"
          autoComplete="email"
          placeholder="Email"
          required
        />
      </Field>

      <Field className="sm:col-span-2">
        <FieldLabel htmlFor="message" className="sr-only">Message</FieldLabel>
        <Textarea
          id="message"
          name="message"
          rows={4}
          placeholder="Message"
          required
        />
      </Field>
    </FieldGroup>

    <div class="m-auto mt-6 max-w-xl">
      <Button type="submit" className="w-full" data-contact-submit>
        Submit
      </Button>
    </div>

    <p class="mt-4 min-h-5 text-center text-sm text-muted-foreground" data-contact-status aria-live="polite"></p>
  </form>
</section>

<script>
  import { actions } from "astro:actions"

  const form = document.querySelector<HTMLFormElement>("[data-contact-form]")
  const submit = document.querySelector<HTMLButtonElement>("[data-contact-submit]")
  const status = document.querySelector<HTMLElement>("[data-contact-status]")

  form?.addEventListener("submit", async (event) => {
    event.preventDefault()

    if (!form.reportValidity()) return

    const originalLabel = submit?.textContent ?? "Submit"
    if (submit) {
      submit.disabled = true
      submit.textContent = "Submitting..."
    }
    if (status) {
      status.textContent = ""
      status.className = "mt-4 min-h-5 text-center text-sm text-muted-foreground"
    }

    const { error } = await actions.sendContact(new FormData(form))

    if (error) {
      if (status) {
        status.textContent = error.message || "An error occurred. Please try again."
        status.className = "mt-4 min-h-5 text-center text-sm text-destructive"
      }
    } else {
      form.reset()
      if (status) {
        status.textContent = "Message sent successfully."
        status.className = "mt-4 min-h-5 text-center text-sm text-muted-foreground"
      }
    }

    if (submit) {
      submit.disabled = false
      submit.textContent = originalLabel
    }
  })
</script>
