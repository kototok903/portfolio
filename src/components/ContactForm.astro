---
import { actions } from "astro:actions"
import Button from "@/components/ui/Button.astro"
---

<section id="contact-form" class="relative isolate m-auto max-w-3xl scroll-mt-32">
  <h1 class="title">Contact me</h1>

  <form method="POST" action={actions.sendContact} class="mt-6 lg:flex-auto" data-contact-form>
    <div class="hidden" aria-hidden>
      <label>
        Website
        <input name="website" tabindex="-1" autocomplete="off" />
      </label>
    </div>

    <div class="grid grid-cols-1 gap-6 sm:grid-cols-2">
      <label>
        <span class="sr-only">Name</span>
        <input
          id="name"
          name="name"
          class="flex h-9 w-full min-w-0 rounded-md border border-input bg-input/90 px-3 py-1 text-base shadow-xs outline-none transition-[color,box-shadow] placeholder:text-muted-foreground focus-visible:border-ring focus-visible:ring-[3px] focus-visible:ring-ring/50 disabled:pointer-events-none disabled:cursor-not-allowed disabled:opacity-50 md:text-sm"
          type="text"
          placeholder="Name"
          autocomplete="given-name"
          minlength="2"
          required
        />
      </label>

      <label>
        <span class="sr-only">Email</span>
        <input
          id="email"
          name="email"
          class="flex h-9 w-full min-w-0 rounded-md border border-input bg-input/90 px-3 py-1 text-base shadow-xs outline-none transition-[color,box-shadow] placeholder:text-muted-foreground focus-visible:border-ring focus-visible:ring-[3px] focus-visible:ring-ring/50 disabled:pointer-events-none disabled:cursor-not-allowed disabled:opacity-50 md:text-sm"
          type="email"
          autocomplete="email"
          placeholder="Email"
          required
        />
      </label>

      <label class="sm:col-span-2">
        <span class="sr-only">Message</span>
        <textarea
          name="message"
          class="field-sizing-content min-h-16 w-full rounded-md border border-input bg-input/90 px-3 py-2 text-base shadow-xs outline-none transition-[color,box-shadow] placeholder:text-muted-foreground focus-visible:border-ring focus-visible:ring-[3px] focus-visible:ring-ring/50 disabled:cursor-not-allowed disabled:opacity-50 md:text-sm"
          rows="4"
          placeholder="Message"
          required></textarea>
      </label>
    </div>

    <div class="m-auto mt-6 max-w-xl">
      <Button type="submit" class="w-full animate-button disabled:opacity-50" data-contact-submit>
        Submit
      </Button>
    </div>

    <p class="mt-4 min-h-5 text-center text-sm text-muted-foreground" data-contact-status aria-live="polite"></p>
  </form>
</section>

<script>
  import { actions } from "astro:actions"

  const form = document.querySelector<HTMLFormElement>("[data-contact-form]")
  const submit = document.querySelector<HTMLButtonElement>("[data-contact-submit]")
  const status = document.querySelector<HTMLElement>("[data-contact-status]")

  form?.addEventListener("submit", async (event) => {
    event.preventDefault()

    if (!form.reportValidity()) return

    const originalLabel = submit?.textContent ?? "Submit"
    if (submit) {
      submit.disabled = true
      submit.textContent = "Submitting..."
    }
    if (status) {
      status.textContent = ""
      status.className = "mt-4 min-h-5 text-center text-sm text-muted-foreground"
    }

    const { error } = await actions.sendContact(new FormData(form))

    if (error) {
      if (status) {
        status.textContent = error.message || "An error occurred. Please try again."
        status.className = "mt-4 min-h-5 text-center text-sm text-destructive"
      }
    } else {
      form.reset()
      if (status) {
        status.textContent = "Message sent successfully."
        status.className = "mt-4 min-h-5 text-center text-sm text-muted-foreground"
      }
    }

    if (submit) {
      submit.disabled = false
      submit.textContent = originalLabel
    }
  })
</script>
