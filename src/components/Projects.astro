---
import { Image } from "astro:assets"
import { LinkButton } from "@/components/LinkButton"
import {
  Card,
  CardContent,
  CardFooter,
  CardHeader,
  CardTitle,
} from "@/components/ui/card"
import Tags from "@/components/Tags.astro"
import { projectsData } from "@/lib/projects"
import { ExternalLinkIcon } from "@lucide/astro"

interface Props {
  count?: number
}

const { count } = Astro.props
const projects = count ? projectsData.slice(0, count) : projectsData
---

<section id="projects" class="relative isolate m-auto max-w-3xl scroll-mt-32 pb-32">
  <h1 class="title">Projects</h1>

  <div class="relative">
    <div class="mt-8 flex flex-col gap-12">
      {
        projects.map((project) => (
          <article>
          <Card className="group relative overflow-hidden">
            <div class="flex flex-col-reverse items-start gap-x-10 gap-y-4 md:flex-row md:items-center">
              <div class="md:max-w-[60%]">
                <CardHeader>
                  <CardTitle>{project.title}</CardTitle>
                </CardHeader>

                <CardContent className="flex flex-col gap-4">
                  <p class="text-muted-foreground" set:html={project.description} />

                  <CardFooter className="flex-wrap gap-2 px-0">
                    {project.link && (
                      <LinkButton
                        href={project.link}
                        target="_blank"
                        rel="noopener noreferrer"
                        variant="secondary"
                      >
                        <ExternalLinkIcon aria-hidden />
                        {project.linkText || "Try it"}
                      </LinkButton>
                    )}

                    {project.githubUrl && (
                      <LinkButton
                        href={project.githubUrl}
                        target="_blank"
                        rel="noopener noreferrer"
                        variant="secondary"
                      >
                        <svg fill="currentColor" viewBox="0 0 24 24" aria-hidden>
                          <path
                            fill-rule="evenodd"
                            d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0 1 12 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0 0 22 12.017C22 6.484 17.522 2 12 2z"
                            clip-rule="evenodd"></path>
                        </svg>
                        GitHub Repo
                      </LinkButton>
                    )}
                  </CardFooter>

                  {project.tags && <Tags tags={project.tags} class="mt-4" />}
                </CardContent>
              </div>

              {project.image && (
                <>
                  <Image
                    src={project.image}
                    alt={`${project.title} project screenshot`}
                    class="absolute left-[65%] top-1/2 hidden h-[80%] max-h-64 w-auto -translate-y-1/2 rounded-lg transition-all duration-150 ease-in-out group-hover:left-[60%] md:block"
                  />
                  <Image
                    src={project.image}
                    alt={`${project.title} project screenshot`}
                    class="mx-auto w-[80%] rounded-lg pb-2 md:hidden"
                  />
                </>
              )}
            </div>
          </Card>
          </article>
        ))
      }
    </div>

    {
      count && projectsData.length > count && (
        <div class="mt-12 flex justify-center">
          <LinkButton href="/projects" variant="outline" size="lg">
            See all projects
          </LinkButton>
        </div>
      )
    }
  </div>
</section>
